TARGET = $(subst 64,x86_64,$(subst 32,i686,$(WIN)))-pc-windows-gnu

TARGET_DIR = ./rust/target
LIBDIR = $(TARGET_DIR)/$(TARGET)/@LIBDIR@
STATLIB = $(LIBDIR)/libfreestiler.a
# System libraries required by the Rust staticlib. The bundled DuckDB C++
# (libduckdb-sys) needs several Windows libs that Cargo's --print=native-static-libs
# does not fully report: notably -lrstrtmgr (Restart Manager, used by
# LocalFileSystem), plus -ldbghelp/-lole32/-lshell32. These are harmless when
# DuckDB is not compiled in.
PKG_LIBS = -L$(LIBDIR) -lfreestiler -lrstrtmgr -lws2_32 -ladvapi32 -luserenv -lbcrypt -lntdll -ldbghelp -lole32 -lshell32 -luser32 -lkernel32 -lstdc++ -static-libstdc++

all: $(SHLIB) rust_clean

.PHONY: $(STATLIB)

$(SHLIB): $(STATLIB)

CARGOTMP = $(CURDIR)/.cargo
VENDOR_DIR = vendor

$(STATLIB):
	mkdir -p $(TARGET_DIR)/libgcc_mock
	touch $(TARGET_DIR)/libgcc_mock/libgcc_eh.a
	rm -Rf $(CARGOTMP)

  # If @USE_VENDOR@ is true, use vendored crates for offline compilation.
	if [ "@USE_VENDOR@" = "true" ]; then \
		if [ -d ./vendor ]; then \
			echo "=== Using offline vendor directory ==="; \
			mkdir -p $(CARGOTMP) && \
			cp rust/vendor-config.toml $(CARGOTMP)/config.toml; \
		elif [ -f ./rust/vendor.tar.xz ]; then \
			echo "=== Using offline vendor tarball ==="; \
			tar xf rust/vendor.tar.xz && \
			mkdir -p $(CARGOTMP) && \
			cp rust/vendor-config.toml $(CARGOTMP)/config.toml; \
		fi; \
	fi

	if [ -d ./vendor ]; then \
		find ./vendor -type f \( -name '._*' -o -name '.DS_Store' \) -delete; \
	fi

	# Build the project using Cargo with additional flags
	export CARGO_HOME=$(CARGOTMP) && \
	export LIBRARY_PATH="$(LIBRARY_PATH);$(CURDIR)/$(TARGET_DIR)/libgcc_mock" && \
		RUSTFLAGS="$(RUSTFLAGS) --print=native-static-libs" cargo build @CRAN_FLAGS@ @FEATURES@ --target=$(TARGET) --lib @PROFILE@ --manifest-path=rust/Cargo.toml --target-dir=$(TARGET_DIR)

	# Always clean up CARGOTMP
	rm -Rf $(CARGOTMP);

rust_clean: $(SHLIB)
	rm -Rf $(CARGOTMP) $(VENDOR_DIR) @CLEAN_TARGET@

clean:
	rm -Rf $(SHLIB) $(STATLIB) $(OBJECTS) $(TARGET_DIR) $(VENDOR_DIR)
